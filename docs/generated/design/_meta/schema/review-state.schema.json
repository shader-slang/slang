{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shader-slang.github.io/generated/design/review-state.schema.json",
  "title": "LLM-generated docs review and remediation ledger",
  "description": "Sibling of freshness.json that records the most recent review and remediation cycle per document. Computed freshness (review-fresh, remediation-fresh) is derived from this file and the target documents' front-matter; it is not stored.",
  "type": "object",
  "required": ["schema_version", "documents"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "documents": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "last_reviewed": { "$ref": "#/$defs/reviewEntry" },
        "last_remediated": { "$ref": "#/$defs/remediationEntry" }
      }
    },
    "reviewEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_model",
        "reviewed_at",
        "target_doc_source_commit",
        "target_doc_watched_paths_digest",
        "finding_count",
        "severity_breakdown",
        "report_path"
      ],
      "properties": {
        "reviewer_model": { "type": "string" },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "target_doc_source_commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
        "target_doc_watched_paths_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "finding_count": { "type": "integer", "minimum": 0 },
        "severity_breakdown": {
          "type": "object",
          "additionalProperties": false,
          "required": ["critical", "major", "minor", "nit"],
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "nit": { "type": "integer", "minimum": 0 }
          }
        },
        "report_path": { "type": "string" }
      }
    },
    "remediationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remediator_model",
        "remediated_at",
        "review_report_ref",
        "actions",
        "report_path"
      ],
      "properties": {
        "remediator_model": { "type": "string" },
        "remediated_at": { "type": "string", "format": "date-time" },
        "review_report_ref": { "type": "string" },
        "actions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fixed", "rejected_bogus", "rejected_out_of_scope", "deferred", "escalated"],
          "properties": {
            "fixed": { "type": "integer", "minimum": 0 },
            "rejected_bogus": { "type": "integer", "minimum": 0 },
            "rejected_out_of_scope": { "type": "integer", "minimum": 0 },
            "deferred": { "type": "integer", "minimum": 0 },
            "escalated": { "type": "integer", "minimum": 0 }
          }
        },
        "report_path": { "type": "string" }
      }
    }
  }
}
