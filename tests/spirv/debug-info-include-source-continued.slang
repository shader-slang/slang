//TEST:SIMPLE(filecheck=CHECK):-target spirv -g1 -debug-info-include-source -emit-spirv-directly -preserve-embedded-source
//TEST:SIMPLE(filecheck=CHECK_G2):-target spirv -g2 -debug-info-include-source -emit-spirv-directly -preserve-embedded-source

// A source file larger than the SPIR-V literal-string limit must have its embedded source
// split across a head plus one or more `...Continued` tails. The padding below pushes this file
// past the limit; a unique marker placed AFTER the padding proves the post-boundary source is
// preserved (not truncated or emitted empty). The two directives exercise both continuation
// paths on the same >65535-byte source: the core `OpSource`/`OpSourceContinued` path at `-g1`
// (CHECK), and the NonSemantic `DebugSource`/`DebugSourceContinued` path at `-g2` (CHECK_G2),
// which shares the same UTF-8-safe chunker.

RWStructuredBuffer<float> outputBuffer;

[shader("compute")]
[numthreads(1, 1, 1)]
void computeMain(uint3 tid : SV_DispatchThreadID)
{
    outputBuffer[0] = 1.0f;
}

