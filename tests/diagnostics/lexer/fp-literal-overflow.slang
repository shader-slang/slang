// Regression test for #11276 (Case 1): a long-digit floating-point literal
// would silently saturate to +INF. The previous accumulator in
// `getFloatingPointLiteralValue` did `value = value * radix + digit` for
// every digit; with hundreds of significant digits the running double would
// overflow `DBL_MAX` and stick at `+INF`, and the compensating `value /=
// divisor` then produced `INF / 10^N == INF`. The fix routes the literal
// through `strtod`, which performs correctly-rounded IEEE 754 conversion
// regardless of digit count. Cross-ref the previously closed #332.

//TEST:SIMPLE(filecheck=CHECK):-target hlsl -stage compute -entry main

RWStructuredBuffer<float> outputBuffer;

[shader("compute")]
[numthreads(1, 1, 1)]
void main(uint3 tid : SV_DispatchThreadID)
{
    // ~1000-digit pi literal. The float-precision result must be the
    // closest single-precision float to pi (`3.14159274…f`), not `+INF`.
    outputBuffer[0] = 3.;

    // Spot-check a few standard well-formed float literals are unaffected.
    outputBuffer[1] = 3.14;
    outputBuffer[2] = 2.5e-3;
    outputBuffer[3] = 0x1.4p+3;
}

// CHECK: 3.14159274101257324f
// CHECK: 3.1400001049041748f
// CHECK: 0.00249999994412065f
// CHECK: 10.0f
