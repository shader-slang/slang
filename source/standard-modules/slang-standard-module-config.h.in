#ifndef SLANG_STANDARD_MODULE_CONFIG_H_INCLUDED
#define SLANG_STANDARD_MODULE_CONFIG_H_INCLUDED

// Standard module configuration - generated from slang-standard-module-config.h.in

// Directory name for the standard module root relative to libslang location
#define SLANG_STANDARD_MODULE_DIR_NAME "@SLANG_STANDARD_MODULE_DIR_NAME@"

// Installation destination for standard modules (for release packages)
#define SLANG_STANDARD_MODULE_INSTALL_DIR "@SLANG_STANDARD_MODULE_INSTALL_DIR@"

// Module file name for the neural module
#define SLANG_NEURAL_MODULE_FILE_NAME "@SLANG_NEURAL_MODULE_FILE_NAME@"

// Module file name for the experimental workgraph module
#define SLANG_WORKGRAPH_MODULE_FILE_NAME "@SLANG_WORKGRAPH_MODULE_FILE_NAME@"

#endif // SLANG_STANDARD_MODULE_CONFIG_H_INCLUDED
